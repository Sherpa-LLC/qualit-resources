---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection } from 'astro:content';

const { business, contact, cta } = config;
const allAreas = [...config.serviceAreas.primary, ...config.serviceAreas.secondary];

const allServices = await getCollection('services');
const services = allServices.sort((a, b) => a.data.order - b.data.order);

function slugify(str: string): string {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

export async function getStaticPaths() {
  const { config: c } = await import('../../config');
  const areas = [...c.serviceAreas.primary, ...c.serviceAreas.secondary];
  return areas.map((area) => ({
    params: { slug: area.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') },
    props: { area },
  }));
}

const { area } = Astro.props;
const areaSlug = slugify(area);
const isPrimary = config.serviceAreas.primary.includes(area);
---

<BaseLayout
  title={`${business.name} in ${area}, ${contact.address.state}`}
  description={`${business.name} proudly serves ${area}, ${contact.address.state}. ${business.description} Contact us today for a free consultation.`}
  schemaType="service"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Locations', url: '/locations' },
    { name: area, url: `/locations/${areaSlug}` },
  ]}
>
  <!-- HERO -->
  <section class="relative py-28 lg:py-36 overflow-hidden" style="background: var(--color-secondary);">
    <div class="absolute inset-0 grid-pattern-dark" aria-hidden="true"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 60% 50%, rgba(37,99,235,0.1) 0%, transparent 50%);" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label justify-center mb-4" style="color: var(--color-primary-light);">Serving {area}</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.025em;">
        {business.name} in {area}, {contact.address.state}
      </h1>
      <p class="text-lg max-w-2xl mx-auto mb-8" style="color: var(--color-text-on-dark-muted);">
        Trusted {business.tagline.toLowerCase()} serving {area} and the surrounding {contact.address.state} communities.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
        <h2>Your Local {business.name} Team in {area}</h2>
        <p>
          {area} organizations trust {business.name} for reliable, professional IT staffing and STEM consulting services.
          {isPrimary
            ? `As one of our primary service areas, ${area} receives priority scheduling and dedicated account management.`
            : `We proudly extend our full range of services to ${area} and the surrounding communities.`
          }
        </p>
        <p>
          Whether you need contract staffing, direct placement, or a comprehensive consulting engagement, our experienced team brings the same
          dedication and expertise to every client in {area}.
        </p>
        <p>
          Call us at <a href={`tel:${contact.phoneRaw}`}>{contact.phone}</a> or
          <a href="/contact">submit an inquiry</a> to get started.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES IN THIS AREA -->
  <section class="py-16 lg:py-24 grid-pattern" style="background: var(--color-bg-alt);">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="section-label mb-4 reveal">Our Services</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
        Services Available in {area}
      </h2>
      <p class="text-lg mb-12 max-w-2xl reveal" style="color: var(--color-text-muted);">
        We offer our full range of IT staffing and consulting services to {area} organizations.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((svc, i) => (
          <a
            href={`/services/${svc.data.slug}`}
            class="group p-6 rounded-xl transition-all duration-300 hover:-translate-y-1 reveal"
            style={`background: var(--color-surface); border: 1px solid var(--color-border); transition-delay: ${i * 80}ms;`}
          >
            <h3 class="text-xl font-bold mb-2 group-hover:text-[var(--color-primary)] transition-colors" style="font-family: var(--font-family-display);">
              {svc.data.title}
            </h3>
            <p class="text-sm mb-4" style="color: var(--color-text-muted);">{svc.data.shortDescription}</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold" style="color: var(--color-primary);">
              Learn More
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US FOR THIS AREA -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-10 reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
        Why {area} Chooses {business.name}
      </h2>
      <div class="space-y-6">
        {[
          {
            num: '01',
            title: 'Local Knowledge',
            desc: `We know ${area} and ${contact.address.state} inside and out — the local talent market, industry landscape, and what works best for organizations in this area.`,
          },
          {
            num: '02',
            title: 'Fast Response Times',
            desc: isPrimary
              ? `Based nearby, we can respond quickly. As a primary service area, ${area} receives priority scheduling and dedicated account support.`
              : `We serve ${area} regularly and can accommodate your timeline. Our team is responsive and committed to your success.`,
          },
          {
            num: '03',
            title: 'Trusted by Your Peers',
            desc: `We've built our reputation one placement at a time across ${contact.address.state}. Enterprise organizations in ${area} trust us to deliver top-tier talent consistently.`,
          },
        ].map((item, i) => (
          <div class="flex gap-5 p-6 rounded-xl reveal" style={`background: var(--color-surface); border: 1px solid var(--color-border); transition-delay: ${i * 100}ms;`}>
            <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center font-bold text-sm text-white" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
              {item.num}
            </div>
            <div>
              <h3 class="font-bold text-lg mb-2">{item.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER LOCATIONS -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label justify-center mb-4 reveal">Service Areas</p>
      <h2 class="text-2xl font-bold mb-8 reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
        We Also Serve
      </h2>
      <div class="flex flex-wrap justify-center gap-3 reveal">
        {allAreas.filter(a => a !== area).map((a) => (
          <a
            href={`/locations/${slugify(a)}`}
            class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-200 hover:-translate-y-0.5"
            style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-light);"
          >
            {a}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-16 text-center overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-secondary) 60%, var(--color-dark) 100%);">
    <div class="absolute inset-0 circuit-pattern opacity-40" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-4 reveal" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.02em;">
        Ready for Service in {area}?
      </h2>
      <p class="mb-8 reveal" style="color: var(--color-text-on-dark-muted);">
        Get in touch today for a free consultation. We are here to help.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal">
        <a href={cta.primary.href} class="btn-primary">Connect With Our Team</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
