---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';

const { business, contact, cta } = config;

function slugify(str: string): string {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
---

<BaseLayout
  title="Service Areas"
  description={`${business.name} proudly serves ${config.serviceAreas.primary.join(', ')} and surrounding ${contact.address.state} communities.`}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Locations', url: '/locations' }]}
>
  <!-- HERO -->
  <section class="relative py-20 lg:py-28 overflow-hidden" style="background: var(--color-secondary);">
    <div class="absolute inset-0 grid-pattern-dark" aria-hidden="true"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, rgba(37,99,235,0.1) 0%, transparent 50%);" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label justify-center mb-4" style="color: var(--color-primary-light);">Service Areas</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.025em;">
        Areas We Serve
      </h1>
      <p class="text-lg" style="color: var(--color-text-on-dark-muted);">
        {business.name} proudly serves {contact.address.city} and the surrounding {contact.address.state} communities with nationwide reach.
      </p>
    </div>
  </section>

  <!-- PRIMARY AREAS -->
  <section class="py-16 lg:py-24 grid-pattern" style="background: var(--color-bg);">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="section-label mb-4 reveal">Primary Service Areas</p>
      <h2 class="text-3xl font-bold mb-8 reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
        Our Home Turf
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {config.serviceAreas.primary.map((area, i) => (
          <a
            href={`/locations/${slugify(area)}`}
            class="group p-6 rounded-xl transition-all duration-300 hover:-translate-y-1 reveal"
            style={`background: var(--color-surface); border: 1px solid var(--color-border); transition-delay: ${i * 80}ms;`}
          >
            <div class="flex items-center gap-3 mb-2">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%); border: 1px solid rgba(37,99,235,0.12);">
                <svg class="w-4 h-4" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-bold group-hover:text-[var(--color-primary)] transition-colors">
                {area}, {contact.address.state}
              </h3>
            </div>
            <p class="text-sm ml-11" style="color: var(--color-text-muted);">
              Priority scheduling &middot; Fast response
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SECONDARY AREAS -->
  {config.serviceAreas.secondary.length > 0 && (
    <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <p class="section-label mb-4 reveal">Extended Service Areas</p>
        <h2 class="text-3xl font-bold mb-8 reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
          We Also Serve
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {config.serviceAreas.secondary.map((area, i) => (
            <a
              href={`/locations/${slugify(area)}`}
              class="group p-6 rounded-xl transition-all duration-300 hover:-translate-y-1 reveal"
              style={`background: var(--color-surface); border: 1px solid var(--color-border); transition-delay: ${i * 80}ms;`}
            >
              <div class="flex items-center gap-3 mb-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%); border: 1px solid rgba(37,99,235,0.12);">
                  <svg class="w-4 h-4" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <h3 class="text-lg font-bold group-hover:text-[var(--color-primary)] transition-colors">
                  {area}{area !== 'Nationwide' ? `, ${contact.address.state}` : ''}
                </h3>
              </div>
              <p class="text-sm ml-11" style="color: var(--color-text-muted);">
                Full service available
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative py-16 text-center overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-secondary) 60%, var(--color-dark) 100%);">
    <div class="absolute inset-0 circuit-pattern opacity-40" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-4 reveal" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.02em;">
        Don't See Your Area?
      </h2>
      <p class="mb-8 reveal" style="color: var(--color-text-on-dark-muted);">
        Give us a call — we serve organizations nationwide and are always expanding our reach.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal">
        <a href={cta.primary.href} class="btn-primary">Connect With Our Team</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
