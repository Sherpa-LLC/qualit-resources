---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getEntry, getCollection } from 'astro:content';

const { business, contact, cta } = config;

const homepage = await getEntry('pages', 'homepage');
const {
  heroHeadline,
  heroAccent,
  heroSubtext,
  heroImage,
  heroAlt,
  ctaPrimary,
  ctaSecondary,
  trustItems,
  servicesHeading,
  servicesSubheading,
  whyHeading,
  whySubheading,
  whyUs,
  processHeading,
  processSubheading,
  processSteps,
  testimonialsHeading,
  testimonialsSubheading,
  ctaBannerHeading,
  ctaBannerAccent,
  ctaBannerText,
} = homepage.data;

const allServices = await getCollection('services');
const services = allServices.sort((a, b) => a.data.order - b.data.order);

const serviceIcons: Record<string, string> = {
  'it-staffing-recruiting': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />',
  'stem-consulting': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 14.5M14.25 3.104c.251.023.501.05.75.082M5 14.5l-1.395 1.395a.75.75 0 00-.22.53v.954c0 .837.68 1.517 1.518 1.517H7.59a.75.75 0 00.64-.361l.857-1.422M5 14.5l4.087 1.687M19.8 14.5l1.395 1.395a.75.75 0 01.22.53v.954c0 .837-.68 1.517-1.518 1.517h-2.187a.75.75 0 01-.64-.361l-.857-1.422M19.8 14.5l-4.087 1.687m0 0L12 18.25l-2.913-2.063" />',
  'quality-assurance': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />',
  'data-analytics': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v-5.5m3 5.5V8.25m3 3v-2" />',
  'erp-implementations': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313M3 16.5V14.25m0 2.25l2.25-1.313M21 16.5l-2.25-1.313M21 16.5V14.25m-9-5.25l2.25 1.313M12 9V6.75l-2.25 1.313M12 9l-2.25-1.313" />',
  'program-management': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 004.5 9v.878m13.5-3A2.25 2.25 0 0119.5 9v.878m0 0a2.246 2.246 0 00-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0121 12v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6c0-1.007.66-1.86 1.57-2.148" />',
};

const stats = [
  { value: '20+', label: 'Years Experience' },
  { value: '10K+', label: 'Placements Made' },
  { value: '500+', label: 'Enterprise Clients' },
  { value: '98%', label: 'Client Retention' },
];

const industryVerticals = [
  'Retail & E-Commerce',
  'Manufacturing',
  'Financial Services',
  'Healthcare',
  'Insurance',
  'Technology',
  'Energy & Utilities',
  'Government',
];
---

<BaseLayout title={business.name} description={business.description}>
  <!-- HERO — Clean Corporate with Network Visualization -->
  <section class="relative overflow-hidden" style="background: var(--color-secondary); min-height: 92dvh;">
    <!-- Abstract data visualization background -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
        <defs>
          <radialGradient id="hero-glow" cx="65%" cy="45%" r="45%">
            <stop offset="0%" stop-color="rgba(37,99,235,0.15)" />
            <stop offset="100%" stop-color="rgba(37,99,235,0)" />
          </radialGradient>
        </defs>
        <rect fill="url(#hero-glow)" width="100%" height="100%" />
        <!-- Network nodes -->
        <g class="network-nodes" stroke="rgba(37,99,235,0.25)" stroke-width="1" fill="none">
          <line x1="55%" y1="20%" x2="70%" y2="35%" style="animation: draw-line 3s ease-in-out infinite;" />
          <line x1="70%" y1="35%" x2="85%" y2="25%" style="animation: draw-line 3s ease-in-out infinite 0.5s;" />
          <line x1="70%" y1="35%" x2="75%" y2="55%" style="animation: draw-line 3s ease-in-out infinite 1s;" />
          <line x1="60%" y1="60%" x2="75%" y2="55%" style="animation: draw-line 3s ease-in-out infinite 1.5s;" />
          <line x1="75%" y1="55%" x2="90%" y2="50%" style="animation: draw-line 3s ease-in-out infinite 0.8s;" />
          <line x1="55%" y1="20%" x2="45%" y2="35%" style="animation: draw-line 3s ease-in-out infinite 0.3s;" />
          <line x1="60%" y1="60%" x2="50%" y2="75%" style="animation: draw-line 3s ease-in-out infinite 1.2s;" />
          <line x1="85%" y1="25%" x2="92%" y2="40%" style="animation: draw-line 3s ease-in-out infinite 0.7s;" />
          <line x1="90%" y1="50%" x2="95%" y2="65%" style="animation: draw-line 3s ease-in-out infinite 1.8s;" />
          <line x1="60%" y1="60%" x2="70%" y2="75%" style="animation: draw-line 3s ease-in-out infinite 2s;" />
        </g>
        <!-- Node circles -->
        <g fill="rgba(37,99,235,0.6)">
          <circle cx="55%" cy="20%" r="4" style="animation: pulse-node 3s ease-in-out infinite;" />
          <circle cx="70%" cy="35%" r="5" style="animation: pulse-node 3s ease-in-out infinite 0.5s;" />
          <circle cx="85%" cy="25%" r="3.5" style="animation: pulse-node 3s ease-in-out infinite 1s;" />
          <circle cx="75%" cy="55%" r="4.5" style="animation: pulse-node 3s ease-in-out infinite 1.5s;" />
          <circle cx="60%" cy="60%" r="4" style="animation: pulse-node 3s ease-in-out infinite 0.8s;" />
          <circle cx="90%" cy="50%" r="3" style="animation: pulse-node 3s ease-in-out infinite 1.2s;" />
          <circle cx="45%" cy="35%" r="3" style="animation: pulse-node 3s ease-in-out infinite 0.3s;" />
          <circle cx="50%" cy="75%" r="3.5" style="animation: pulse-node 3s ease-in-out infinite 2s;" />
          <circle cx="92%" cy="40%" r="2.5" style="animation: pulse-node 3s ease-in-out infinite 0.7s;" />
          <circle cx="95%" cy="65%" r="3" style="animation: pulse-node 3s ease-in-out infinite 1.8s;" />
          <circle cx="70%" cy="75%" r="3" style="animation: pulse-node 3s ease-in-out infinite 2.2s;" />
        </g>
        <!-- Floating dot grid on the right -->
        <g fill="rgba(148,163,184,0.15)">
          {Array.from({ length: 8 }).map((_, row) =>
            Array.from({ length: 6 }).map((_, col) => (
              <circle
                cx={`${55 + col * 8}%`}
                cy={`${15 + row * 10}%`}
                r="1.2"
                style={`animation: float-particle ${2.5 + (row + col) * 0.3}s ease-in-out infinite ${(row * 6 + col) * 0.15}s;`}
              />
            ))
          )}
        </g>
      </svg>
      <!-- Gradient overlay for text readability -->
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(15,23,42,0.97) 0%, rgba(15,23,42,0.85) 45%, rgba(15,23,42,0.4) 70%, transparent 100%);"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: 92dvh;">
      <div class="max-w-2xl py-20">
        <div class="flex items-center gap-3 mb-8">
          <div class="h-px w-10" style="background: var(--color-primary);"></div>
          <span class="text-xs font-bold uppercase tracking-[0.15em]" style="color: var(--color-primary);">Enterprise IT Solutions</span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-[4.25rem] font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); line-height: 1.06; letter-spacing: -0.035em;">
          {heroHeadline}
          {heroAccent && (
            <span class="block text-gradient">{heroAccent}</span>
          )}
        </h1>
        <p class="text-lg sm:text-xl mb-10 max-w-xl" style="color: var(--color-text-on-dark-muted); line-height: 1.7;">
          {heroSubtext}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-14">
          <a href={cta.primary.href} class="btn-primary">{ctaPrimary || cta.primary.label}</a>
          {ctaSecondary && (
            <a href="/services" class="btn-ghost">{ctaSecondary}</a>
          )}
        </div>
        {trustItems && trustItems.length > 0 && (
          <div class="flex flex-wrap gap-x-8 gap-y-3">
            {trustItems.map((item: any) => (
              <span class="flex items-center gap-2.5 text-sm" style="color: var(--color-text-on-dark-muted);">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item.label}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- SERVICES — Tech Category Tiles with Icons -->
  <section class="relative py-24 lg:py-32 grid-pattern" style="background: var(--color-bg);">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        {servicesSubheading && <p class="section-label mb-4 reveal">{servicesSubheading}</p>}
        <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-bold reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
          {servicesHeading || 'Our Services'}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((svc, i) => (
          <a
            href={`/services/${svc.data.slug}`}
            class="group relative rounded-xl overflow-hidden transition-all duration-400 reveal"
            style={`background: var(--color-surface); border: 1px solid var(--color-border); transition-delay: ${i * 80}ms;`}
          >
            <!-- Hover expand overlay -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-400 z-10 flex flex-col justify-end p-8" style="background: linear-gradient(180deg, rgba(15,23,42,0) 0%, rgba(15,23,42,0.92) 60%, rgba(15,23,42,0.98) 100%);">
              <h3 class="text-xl font-bold mb-2 text-white" style="font-family: var(--font-family-display);">{svc.data.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-on-dark-muted);">{svc.data.shortDescription}</p>
              <span class="inline-flex items-center gap-2 mt-4 text-sm font-semibold" style="color: var(--color-primary-light);">
                Explore Service
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
                </svg>
              </span>
            </div>
            <!-- Card content -->
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={svc.data.heroImage}
                alt={svc.data.heroAlt}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                width="600"
                height="375"
                loading="lazy"
              />
            </div>
            <div class="p-6 flex items-start gap-4">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.05) 100%); border: 1px solid rgba(37,99,235,0.15);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={serviceIcons[svc.data.slug] || serviceIcons['it-staffing-recruiting']} />
              </div>
              <div class="min-w-0">
                <h3 class="text-lg font-bold mb-1" style="font-family: var(--font-family-display);">{svc.data.title}</h3>
                <p class="text-sm line-clamp-2" style="color: var(--color-text-muted);">{svc.data.shortDescription}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY US — Enterprise Trust Metrics + Stats -->
  {whyUs && whyUs.length > 0 && (
    <section class="relative py-24 lg:py-32 overflow-hidden" style="background: var(--color-secondary);">
      <div class="absolute inset-0 grid-pattern-dark" aria-hidden="true"></div>
      <div class="absolute top-0 right-0 w-1/2 h-full" aria-hidden="true" style="background: radial-gradient(ellipse at 80% 50%, rgba(37,99,235,0.08) 0%, transparent 60%);"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mb-16">
          {whySubheading && <p class="section-label mb-4 reveal" style="color: var(--color-primary-light);">{whySubheading}</p>}
          <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-bold mb-6 reveal" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.02em;">
            {whyHeading || `Why ${business.name}?`}
          </h2>
        </div>

        <!-- Stat blocks with animated counters -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-20">
          {stats.map((stat, i) => (
            <div class="text-center p-6 rounded-xl reveal" style={`background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(8px); transition-delay: ${i * 100}ms;`}>
              <div class="text-3xl sm:text-4xl font-bold mb-1 stat-counter" style="color: var(--color-primary-light);" data-target={stat.value}>
                {stat.value}
              </div>
              <div class="text-xs font-medium uppercase tracking-wider" style="color: var(--color-text-on-dark-muted);">
                {stat.label}
              </div>
            </div>
          ))}
        </div>

        <!-- Why us detail cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {whyUs.map((item: any, i: number) => (
            <div class="group p-8 rounded-xl reveal transition-all duration-300 hover:-translate-y-1" style={`background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); transition-delay: ${i * 120}ms;`}>
              <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
                </svg>
              </div>
              <h3 class="text-lg font-bold mb-3" style="color: var(--color-text-on-dark);">{item.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-on-dark-muted);">{item.description}</p>
            </div>
          ))}
        </div>

        <!-- Industry logos placeholder row -->
        <div class="mt-20 pt-12 reveal" style="border-top: 1px solid rgba(255,255,255,0.08);">
          <p class="text-xs font-bold uppercase tracking-[0.12em] mb-8 text-center" style="color: var(--color-text-on-dark-muted);">Trusted Across Industries</p>
          <div class="flex flex-wrap justify-center gap-x-10 gap-y-4">
            {industryVerticals.map((industry) => (
              <span class="text-sm font-medium px-4 py-2 rounded-full" style="color: rgba(248,250,252,0.5); border: 1px solid rgba(255,255,255,0.06);">
                {industry}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- PROCESS — Tech Workflow Diagram -->
  {processSteps && processSteps.length > 0 && (
    <section class="py-24 lg:py-32" style="background: var(--color-bg);">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          {processSubheading && <p class="section-label justify-center mb-4 reveal">{processSubheading}</p>}
          <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-bold reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
            {processHeading || 'How It Works'}
          </h2>
        </div>

        <!-- Process workflow with connected nodes -->
        <div class="relative">
          <!-- Connection line (desktop) -->
          <div class="hidden lg:block absolute top-[52px] left-[12.5%] right-[12.5%] h-px" style="background: linear-gradient(90deg, transparent, var(--color-primary), var(--color-primary), transparent);" aria-hidden="true">
            <!-- Data flow dots -->
            <div class="absolute top-1/2 -translate-y-1/2 w-2 h-2 rounded-full" style="background: var(--color-primary); animation: data-flow 2s ease-in-out infinite; left: 20%;"></div>
            <div class="absolute top-1/2 -translate-y-1/2 w-2 h-2 rounded-full" style="background: var(--color-primary); animation: data-flow 2s ease-in-out infinite 0.5s; left: 50%;"></div>
            <div class="absolute top-1/2 -translate-y-1/2 w-2 h-2 rounded-full" style="background: var(--color-primary); animation: data-flow 2s ease-in-out infinite 1s; left: 80%;"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
            {processSteps.map((step: any, i: number) => (
              <div class="relative text-center reveal" style={`transition-delay: ${i * 120}ms;`}>
                <!-- Node circle -->
                <div class="relative mx-auto w-[104px] h-[104px] rounded-full flex items-center justify-center mb-8" style="background: var(--color-surface); border: 2px solid var(--color-border); box-shadow: var(--shadow-card);">
                  <div class="w-14 h-14 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%);">
                    <span class="text-2xl font-bold" style="color: var(--color-primary);">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                  </div>
                  <!-- Active pulse -->
                  <div class="absolute inset-0 rounded-full" style="animation: pulse-node 3s ease-in-out infinite ${i * 0.5}s; border: 2px solid var(--color-primary); opacity: 0;"></div>
                </div>
                <!-- Mobile connector -->
                {i < processSteps.length - 1 && (
                  <div class="lg:hidden w-px h-8 mx-auto -mt-4 mb-4" style="background: linear-gradient(to bottom, var(--color-primary), transparent);" aria-hidden="true"></div>
                )}
                <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-family-display);">{step.title}</h3>
                <p class="text-sm max-w-xs mx-auto" style="color: var(--color-text-muted);">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- TESTIMONIALS — Enterprise Professional Styling -->
  {config.testimonials.length > 0 && (
    <section class="py-24 lg:py-32" style="background: var(--color-bg-alt);">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          {testimonialsSubheading && <p class="section-label justify-center mb-4 reveal">{testimonialsSubheading}</p>}
          <h2 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-bold reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
            {testimonialsHeading || 'What Our Clients Say'}
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {config.testimonials.map((t, i) => (
            <blockquote class="relative p-8 lg:p-10 rounded-xl reveal" style={`background: var(--color-surface); border: 1px solid var(--color-border); transition-delay: ${i * 100}ms;`}>
              <!-- Quote mark -->
              <div class="absolute -top-4 left-8 w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
                </svg>
              </div>
              <p class="text-base leading-relaxed mb-8 mt-2" style="color: var(--color-text-light);">{t.quote}</p>
              <footer class="flex items-center gap-4" style="border-top: 1px solid var(--color-border); padding-top: 1.25rem;">
                <div class="w-11 h-11 rounded-full flex items-center justify-center font-bold text-sm text-white flex-shrink-0" style="background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-dark-alt) 100%);">
                  {t.author.charAt(0)}
                </div>
                <div>
                  <cite class="not-italic font-bold text-sm block">{t.author}</cite>
                  <p class="text-xs" style="color: var(--color-text-muted);">{t.location}</p>
                </div>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA BANNER — Blue-to-Dark Gradient with Circuit Pattern -->
  <section class="relative py-24 text-center overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-secondary) 60%, var(--color-dark) 100%);">
    <div class="absolute inset-0 circuit-pattern opacity-50" aria-hidden="true"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, rgba(37,99,235,0.15) 0%, transparent 60%);" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 reveal" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.02em;">
        {ctaBannerHeading || 'Ready to Get Started'}
        {ctaBannerAccent && (
          <span class="block text-gradient">{ctaBannerAccent}</span>
        )}
      </h2>
      <p class="text-lg mb-10 max-w-xl mx-auto reveal" style="color: var(--color-text-on-dark-muted);">
        {ctaBannerText || `Contact ${business.name} today for a free consultation.`}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal">
        <a href={cta.primary.href} class="btn-primary">Connect With Our Team</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
