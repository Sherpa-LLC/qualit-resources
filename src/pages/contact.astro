---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';

const { business, contact, hours } = config;

const industryOptions = [
  'Retail & E-Commerce',
  'Manufacturing',
  'Financial Services & Banking',
  'Healthcare',
  'Insurance',
  'Technology',
  'Energy & Utilities',
  'Government',
  'Other',
];

const teamSizeOptions = [
  '1-10 employees',
  '11-50 employees',
  '51-200 employees',
  '201-1,000 employees',
  '1,001-5,000 employees',
  '5,000+ employees',
];

const timelineOptions = [
  'Immediately (within 2 weeks)',
  'Within 1 month',
  'Within 1-3 months',
  'Within 3-6 months',
  'Planning / No immediate need',
];
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${business.name}. Call ${contact.phone} or fill out our contact form for a free consultation.`}
  schemaType="contact"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact' }]}
>
  <!-- HERO -->
  <section class="relative py-20 lg:py-28 overflow-hidden" style="background: var(--color-secondary);">
    <div class="absolute inset-0 grid-pattern-dark" aria-hidden="true"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 50%, rgba(37,99,235,0.1) 0%, transparent 50%);" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label justify-center mb-4" style="color: var(--color-primary-light);">Get In Touch</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.025em;">
        Connect With Our Team
      </h1>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-on-dark-muted);">
        Ready to find the right talent for your organization? Let us know about your needs and we will craft a custom solution.
      </p>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- ENTERPRISE INQUIRY FORM -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold mb-2" style="font-family: var(--font-family-display);">Enterprise Inquiry</h2>
          <p class="text-sm mb-8" style="color: var(--color-text-muted);">Fill out the form below and our team will respond within one business day.</p>

          <form class="space-y-6" action="/contact" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold mb-2">Full Name *</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                  placeholder="John Smith"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-semibold mb-2">Company *</label>
                <input type="text" id="company" name="company" required
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                  placeholder="Acme Corp"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-semibold mb-2">Business Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                  placeholder="john@company.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold mb-2">Phone</label>
                <input type="tel" id="phone" name="phone"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1"
                  style="border: 1px solid var(--color-border); background: var(--color-surface);"
                  placeholder="(555) 123-4567"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
              <!-- Industry Selector -->
              <div>
                <label for="industry" class="block text-sm font-semibold mb-2">Industry</label>
                <select id="industry" name="industry"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1 appearance-none"
                  style="border: 1px solid var(--color-border); background: var(--color-surface); background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2364748B%22 stroke-width=%222%22%3E%3Cpath d=%22m6 9 6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center;"
                >
                  <option value="">Select industry</option>
                  {industryOptions.map((opt) => (
                    <option value={opt}>{opt}</option>
                  ))}
                </select>
              </div>
              <!-- Team Size Selector -->
              <div>
                <label for="team-size" class="block text-sm font-semibold mb-2">Team Size</label>
                <select id="team-size" name="team-size"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1 appearance-none"
                  style="border: 1px solid var(--color-border); background: var(--color-surface); background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2364748B%22 stroke-width=%222%22%3E%3Cpath d=%22m6 9 6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center;"
                >
                  <option value="">Select size</option>
                  {teamSizeOptions.map((opt) => (
                    <option value={opt}>{opt}</option>
                  ))}
                </select>
              </div>
              <!-- Timeline Dropdown -->
              <div>
                <label for="timeline" class="block text-sm font-semibold mb-2">Timeline</label>
                <select id="timeline" name="timeline"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1 appearance-none"
                  style="border: 1px solid var(--color-border); background: var(--color-surface); background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2364748B%22 stroke-width=%222%22%3E%3Cpath d=%22m6 9 6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center;"
                >
                  <option value="">Select timeline</option>
                  {timelineOptions.map((opt) => (
                    <option value={opt}>{opt}</option>
                  ))}
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold mb-2">How can we help? *</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-lg text-sm transition-all duration-200 resize-none focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-1"
                style="border: 1px solid var(--color-border); background: var(--color-surface);"
                placeholder="Tell us about your staffing needs, project requirements, or any questions..."
              ></textarea>
            </div>

            <!-- Cloudflare Turnstile -->
            <div class="cf-turnstile" data-sitekey="0x4AAAAAAAe0EJ2NwHkMsJro" data-theme="light"></div>

            <button type="submit" class="btn-primary w-full sm:w-auto">
              Submit Inquiry
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </button>
          </form>
        </div>

        <!-- INFO SIDEBAR -->
        <div class="lg:col-span-2 space-y-6">
          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%); border: 1px solid rgba(37,99,235,0.12);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Call Us</h3>
            </div>
            <a href={`tel:${contact.phoneRaw}`} class="text-xl font-bold block" style="color: var(--color-primary);">
              {contact.phone}
            </a>
            <p class="text-xs mt-1" style="color: var(--color-text-muted);">Monday - Friday, 8am - 5pm EST</p>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%); border: 1px solid rgba(37,99,235,0.12);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Email</h3>
            </div>
            <a href={`mailto:${contact.email}`} class="font-semibold transition-colors" style="color: var(--color-primary);">
              {contact.email}
            </a>
            <p class="text-xs mt-1" style="color: var(--color-text-muted);">We respond within 1 business day</p>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%); border: 1px solid rgba(37,99,235,0.12);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Location</h3>
            </div>
            <address class="not-italic text-sm leading-relaxed" style="color: var(--color-text-light);">
              {contact.address.street}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </address>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%); border: 1px solid rgba(37,99,235,0.12);">
                <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Hours</h3>
            </div>
            <dl class="space-y-1.5 text-sm">
              {Object.entries(hours).map(([day, h]) => (
                <div class="flex justify-between gap-4">
                  <dt class="capitalize" style="color: var(--color-text-muted);">{day}</dt>
                  <dd class="font-medium">{h}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
