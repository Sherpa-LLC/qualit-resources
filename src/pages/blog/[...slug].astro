---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection, render } from 'astro:content';

const { contact, cta } = config;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, author, metaDescription, heroImage, heroAlt, category, readingTime } = post.data;
const { Content } = await render(post);

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={metaDescription}
  image={heroImage}
  schemaType="blog-post"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: title, url: `/blog/${post.id}` },
  ]}
  blogPost={{ title, description: metaDescription, date, author, image: heroImage }}
>
  <!-- HERO -->
  {heroImage && (
    <section class="relative py-32 lg:py-40 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={heroImage}
          alt={heroAlt || title}
          class="w-full h-full object-cover"
          width="1920"
          height="1080"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(15,23,42,0.88) 0%, rgba(15,23,42,0.78) 40%, rgba(15,23,42,0.92) 100%);"></div>
      </div>
      <div class="absolute inset-0 grid-pattern-dark" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <nav class="mb-6 text-sm flex items-center gap-2" style="color: var(--color-text-on-dark-muted);">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <svg class="w-3.5 h-3.5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
          <svg class="w-3.5 h-3.5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          <span class="truncate" style="color: var(--color-text-on-dark);">{title}</span>
        </nav>
        {category && (
          <span class="inline-block px-3 py-1 text-[11px] font-bold uppercase tracking-wider rounded-full text-white mb-4" style="background: var(--color-primary);">
            {category}
          </span>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); line-height: 1.08; letter-spacing: -0.025em;">
          {title}
        </h1>
        <div class="flex items-center gap-4 text-sm" style="color: var(--color-text-on-dark-muted);">
          <span>{formattedDate}</span>
          {readingTime && (
            <>
              <span class="w-1 h-1 rounded-full" style="background: rgba(255,255,255,0.25);"></span>
              <span>{readingTime}</span>
            </>
          )}
          <span class="w-1 h-1 rounded-full" style="background: rgba(255,255,255,0.25);"></span>
          <span>By {author}</span>
        </div>
      </div>
    </section>
  )}

  <!-- ARTICLE -->
  <article class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary); --tw-prose-bold: var(--color-text);">
        <Content />
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="relative py-16 text-center overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-secondary) 60%, var(--color-dark) 100%);">
    <div class="absolute inset-0 circuit-pattern opacity-40" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4 reveal" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.02em;">
        Ready to Get Started?
      </h2>
      <p class="mb-8 reveal" style="color: var(--color-text-on-dark-muted);">
        Contact us today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal">
        <a href={cta.primary.href} class="btn-primary">Connect With Our Team</a>
        <a href="/blog" class="btn-ghost">&larr; Back to Blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
