---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection } from 'astro:content';

const { business, contact, cta } = config;

const allServices = await getCollection('services');
const services = allServices.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Our Services"
  description={`Explore the IT staffing and STEM consulting services offered by ${business.name}. From recruiting to quality assurance to ERP implementations.`}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Services', url: '/services' }]}
>
  <!-- HERO -->
  <section class="py-20 lg:py-28" style={`background: var(--color-secondary);`}>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4">Our Services</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        IT Staffing & STEM Consulting
      </h1>
      <p class="text-lg" style="color: var(--color-text-on-dark-muted);">
        Comprehensive staffing and consulting solutions to help your organization build, scale, and optimize technical teams.
      </p>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((svc, i) => (
          <a
            href={`/services/${svc.data.slug}`}
            class="group rounded-lg overflow-hidden transition-shadow duration-300 reveal"
            style={`background: var(--color-surface); box-shadow: var(--shadow-card); transition-delay: ${i * 100}ms;`}
          >
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={svc.data.heroImage}
                alt={svc.data.heroAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="600"
                height="375"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h2 class="text-xl font-bold mb-2" style="font-family: var(--font-family-display);">{svc.data.title}</h2>
              <p class="text-sm" style="color: var(--color-text-muted);">{svc.data.shortDescription}</p>
              <span class="inline-block mt-4 text-sm font-semibold" style="color: var(--color-primary);">
                Learn more &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center" style={`background: var(--color-dark);`}>
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-4" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Need Help Finding the Right Service?
      </h2>
      <p class="mb-8" style="color: var(--color-text-on-dark-muted);">
        Contact us today and we will help you determine the best staffing solution for your organization.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
