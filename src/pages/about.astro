---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getEntry, render } from 'astro:content';

const { business, contact, cta } = config;
const allAreas = [...config.serviceAreas.primary, ...config.serviceAreas.secondary];

const about = await getEntry('pages', 'about');
const { heroImage, heroAlt, metaDescription } = about.data;
const { Content } = await render(about);

const industryVerticals = [
  { name: 'Retail & E-Commerce', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />' },
  { name: 'Manufacturing', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.1 3.06a.75.75 0 01-1.14-.644V5.88a.75.75 0 01.386-.659l5.1-2.869a.75.75 0 011.098.66v3.243m-3.932 9.935L16.5 3.67a.75.75 0 011.14.644v11.593a.75.75 0 01-.386.659l-5.1 2.869a.75.75 0 01-1.098-.66v-3.243" />' },
  { name: 'Financial Services', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />' },
  { name: 'Healthcare', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />' },
  { name: 'Insurance', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />' },
  { name: 'Technology', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />' },
  { name: 'Energy & Utilities', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />' },
  { name: 'Government', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />' },
];
---

<BaseLayout
  title="About Us"
  description={metaDescription}
  schemaType="about"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]}
>
  <!-- HERO -->
  <section class="relative py-28 lg:py-36 overflow-hidden" style="background: var(--color-secondary);">
    {heroImage && (
      <div class="absolute inset-0">
        <img src={heroImage} alt={heroAlt || 'About us'} class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.92) 0%, rgba(15,23,42,0.8) 50%, rgba(15,23,42,0.75) 100%);"></div>
      </div>
    )}
    <div class="absolute inset-0 grid-pattern-dark" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label justify-center mb-4" style="color: var(--color-primary-light);">About Us</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.025em;">
        {about.data.title || `About ${business.name}`}
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-on-dark-muted);">
        Since {business.yearFounded}, we've been connecting top IT and STEM talent with enterprise organizations across the nation.
      </p>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
        <Content />
      </div>
    </div>
  </section>

  <!-- INDUSTRY VERTICALS — Icon Grid -->
  <section class="py-16 lg:py-24 grid-pattern" style="background: var(--color-bg-alt);">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="section-label justify-center mb-4 reveal">Industries</p>
        <h2 class="text-3xl sm:text-4xl font-bold reveal" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
          Industry Verticals We Serve
        </h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {industryVerticals.map((v, i) => (
          <div class="group p-6 rounded-xl text-center transition-all duration-300 hover:-translate-y-1 reveal" style={`background: var(--color-surface); border: 1px solid var(--color-border); transition-delay: ${i * 60}ms;`}>
            <div class="w-12 h-12 mx-auto rounded-xl flex items-center justify-center mb-4 transition-colors duration-300" style="background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(37,99,235,0.04) 100%); border: 1px solid rgba(37,99,235,0.12);">
              <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={v.icon} />
            </div>
            <span class="text-sm font-semibold" style="color: var(--color-text);">{v.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HEADQUARTERS -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <p class="section-label mb-4">Headquarters</p>
          <h2 class="text-3xl font-bold mb-6" style="font-family: var(--font-family-display); letter-spacing: -0.02em;">
            Based in Blue Ash, Ohio
          </h2>
          <p class="text-lg mb-6" style="color: var(--color-text-muted);">
            Our headquarters in the heart of Greater Cincinnati's tech corridor positions us at the center of one of the Midwest's most dynamic business communities.
          </p>
          <address class="not-italic p-6 rounded-xl" style="background: var(--color-bg-alt); border: 1px solid var(--color-border);">
            <p class="font-bold mb-2">{business.name}</p>
            <p class="text-sm" style="color: var(--color-text-muted);">
              {contact.address.street}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </p>
            <div class="mt-4 flex flex-col sm:flex-row gap-3">
              <a href={`tel:${contact.phoneRaw}`} class="text-sm font-semibold" style="color: var(--color-primary);">{contact.phone}</a>
              <a href={`mailto:${contact.email}`} class="text-sm font-semibold" style="color: var(--color-primary);">{contact.email}</a>
            </div>
          </address>
        </div>
        <div class="reveal" style="transition-delay: 150ms;">
          <div class="p-6 rounded-xl text-center" style="background: var(--color-bg-alt); border: 1px solid var(--color-border);">
            <p class="section-label justify-center mb-4">Coverage Area</p>
            <h3 class="text-xl font-bold mb-6" style="font-family: var(--font-family-display);">
              Serving {contact.address.city} & Beyond
            </h3>
            <div class="flex flex-wrap justify-center gap-2">
              {allAreas.map((area) => (
                <a href={`/locations/${area.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 hover:-translate-y-0.5" style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-light);">
                  {area}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 text-center overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-secondary) 60%, var(--color-dark) 100%);">
    <div class="absolute inset-0 circuit-pattern opacity-40" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4 reveal" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); letter-spacing: -0.02em;">
        Ready to Work with Us?
      </h2>
      <p class="mb-8 reveal" style="color: var(--color-text-on-dark-muted);">
        Get in touch today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>
