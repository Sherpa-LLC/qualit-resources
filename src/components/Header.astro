---
import { config } from '../config';

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background-color: rgba(15, 23, 42, 0.85); backdrop-filter: blur(16px) saturate(180%); -webkit-backdrop-filter: blur(16px) saturate(180%); border-bottom: 1px solid rgba(255,255,255,0.06);"
>
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="flex items-center justify-between h-[72px] lg:h-[76px]">
      <!-- Logo -->
      <a href="/" class="relative z-50 flex-shrink-0" aria-label={config.business.name}>
        <img
          src="/images/logo.png"
          alt={config.business.name}
          class="h-9 lg:h-11 w-auto"
          width="240"
          height="44"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">
        {config.nav.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'relative px-4 py-2 text-[13px] font-medium tracking-[0.06em] transition-colors duration-200 rounded-md',
                isActive
                  ? 'text-white'
                  : 'text-[rgba(248,250,252,0.55)] hover:text-white',
              ]}
            >
              {item.label}
              {isActive && (
                <span class="absolute bottom-0 left-4 right-4 h-[2px] rounded-full" style="background: var(--color-primary);"></span>
              )}
            </a>
          );
        })}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-5">
        <a
          href={`tel:${config.contact.phoneRaw}`}
          class="flex items-center gap-2 text-[13px] font-medium tracking-wide transition-colors duration-200"
          style="color: rgba(248,250,252,0.55);"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {config.contact.phone}
        </a>
        <a href={config.cta.primary.href} class="btn-primary !min-w-0 !px-5 !py-2.5 !text-[12px]">
          Get Started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden relative z-50 w-10 h-10 flex items-center justify-center rounded-lg transition-colors"
        style="background: rgba(255,255,255,0.06);"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <div class="menu-icon space-y-1.5">
          <span class="block w-5 h-[1.5px] rounded-full bg-white transition-all duration-300 origin-center"></span>
          <span class="block w-5 h-[1.5px] rounded-full bg-white transition-all duration-300"></span>
          <span class="block w-3.5 h-[1.5px] rounded-full bg-white transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
    style="background: linear-gradient(180deg, var(--color-secondary) 0%, var(--color-dark) 100%);"
  >
    <nav class="flex flex-col items-center gap-6" aria-label="Mobile navigation">
      {config.nav.map((item) => (
        <a
          href={item.href}
          class="text-2xl font-bold tracking-tight transition-colors duration-200 text-white hover:text-[var(--color-primary-light)]"
          style="font-family: var(--font-family-display);"
        >
          {item.label}
        </a>
      ))}
      <div class="mt-8 flex flex-col items-center gap-4">
        <a href={config.cta.primary.href} class="btn-primary">
          {config.cta.primary.label}
        </a>
        <a
          href={`tel:${config.contact.phoneRaw}`}
          class="text-lg font-bold tracking-wide"
          style="color: var(--color-primary-light);"
        >
          {config.contact.phone}
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-[72px] lg:h-[76px]"></div>

<!-- Sticky Mobile CTA -->
<div
  class="lg:hidden fixed bottom-0 left-0 right-0 z-40 px-4 py-3 flex items-center justify-between gap-3"
  style="background: rgba(15,23,42,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid rgba(255,255,255,0.08);"
>
  <a
    href={`tel:${config.contact.phoneRaw}`}
    class="flex-1 btn-primary !py-3 text-center"
  >
    <svg class="w-4 h-4 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
    </svg>
    Call Now
  </a>
  <a
    href={config.cta.primary.href}
    class="flex-1 btn-ghost !py-3 !min-w-0 text-center"
  >
    Get Started
  </a>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');
  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    btn.setAttribute('aria-expanded', String(isOpen));
    menu?.classList.toggle('opacity-0', !isOpen);
    menu?.classList.toggle('pointer-events-none', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';

    const spans = btn.querySelectorAll('.menu-icon span');
    if (isOpen) {
      spans[0].style.transform = 'rotate(45deg) translate(4px, 4px)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'rotate(-45deg) translate(3px, -3px)';
      spans[2].style.width = '20px';
    } else {
      spans[0].style.transform = '';
      spans[1].style.opacity = '1';
      spans[2].style.transform = '';
      spans[2].style.width = '14px';
    }
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (isOpen) btn?.click();
    });
  });

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const scrolled = window.scrollY > 20;
        if (header) {
          header.style.backgroundColor = scrolled
            ? 'rgba(15, 23, 42, 0.95)'
            : 'rgba(15, 23, 42, 0.85)';
          header.style.boxShadow = scrolled
            ? '0 1px 24px rgba(15,23,42,0.2)'
            : 'none';
        }
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
